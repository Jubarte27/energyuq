environment
	method_pointer = 'ada'
	tabular_data
		tabular_data_file = 'pce_samples.dat'
        custom_annotated header

model
    id_model = 'SURROGATE'
    surrogate
        responses_pointer = 'energy_response'
        variables_pointer = 'discrete_design'
        global_approx
            reuse_points
            minimum_points
            gaussian_process
                dakota
            dace_method_pointer = 'gauss'
            truth_model_pointer = 'TRUTH'

model
    id_model = 'TRUTH'
    single
        responses_pointer = 'energy_response'
        interface_pointer = 'TRUE_FN'
        variables_pointer = 'discrete_design'

 method,
    id_method = 'pce'
    polynomial_chaos
        normalized
        sparse_grid_level = 3
        model_pointer = 'TRUTH'
        variance_based_decomp
        p_refinement dimension_adaptive sobol
            max_iterations  = 20
            convergence_tol = 1.e-4

method
    id_method = 'ada'
    adaptive_sampling
        samples 3
        refinement_samples 4
        samples_on_emulator = 1000
        final_solutions 1
        model_pointer = 'TRUTH'
        max_iterations 10

method
    id_method = 'gauss'
    gpais
        build_samples 3
        model_pointer = 'TRUTH'

variables
    id_variable = 'discrete_design'
	active all
    relaxed
	discrete_design_range = 2
        initial_point        2           28
        lower_bounds         0            1
        upper_bounds         2           28
        descriptors      'CLK'  'N_THREADS'

interface
    id_interface = 'TRUE_FN'
    analysis_drivers = 'dakota_driver.sh'
        fork
            parameters_file 'energyuq.in'
            results_file 'energyuq.out'
            file_tag
            file_save
        work_directory named 'workdir'
        parameters_format
            aprepro

responses
    id_response = 'energy_response'
    response_functions = 3
    descriptors = 'energy_uj' 'time' 'energy_scaled'
	no_gradients
	no_hessians
