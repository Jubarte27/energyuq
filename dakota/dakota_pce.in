environment,
	method_pointer = 'BandB'
	tabular_data
		tabular_data_file = 'pce_samples.dat'
        custom_annotated header

variables,
    mixed
	active all
	discrete_design_range = 2
		initial_point        2           32
		lower_bounds         0            1
		upper_bounds         2           32
		descriptors      'CLK'  'N_THREADS'

method
  id_method = 'BandB'
  branch_and_bound
    output verbose
    method_pointer = 'ada'

method,
	id_method = 'ada'
	adaptive_sampling
        seed = 42
		max_iterations = 20

interface
    analysis_driver = 'python3 dakota_wrapper.py'
        fork
            file_tag
            file_save
        parameters_format
            aprepro

responses
    response_functions = 1
    descriptors = 'energy_uj'
	numerical_gradients
	no_hessians