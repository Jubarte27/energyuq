environment,
	method_pointer = 'SBGO'
	tabular_data
		tabular_data_file = 'pce_samples.dat'
        custom_annotated header

method
    id_method = 'BandB'
    branch_and_bound
        output verbose
        method_pointer = 'SBGO'

method
    id_method = 'SBGO'
    surrogate_based_global
        model_pointer = 'SURROGATE'
        method_pointer = 'newton'
        max_iterations = 5
        replace_points
        output verbose


method
    id_method 'newton'
    optpp_q_newton
        output verbose

model
    id_model = 'SURROGATE'
    surrogate global
        dace_method_pointer = 'ada'
        correction additive zeroth_order
        gaussian_process dakota


method,
	id_method = 'ada'
	adaptive_sampling
        seed = 42
		max_iterations = 20
        model_pointer = 'TRUTH'
        output verbose

variables,
    relaxed
	active all
	discrete_design_range = 2
		initial_point        2           32
		lower_bounds         0            1
		upper_bounds         2           32
		descriptors      'CLK'  'N_THREADS'

interface
    id_interface = 'TRUE_FN'
    analysis_driver = 'dakota_driver.sh'
        fork
            parameters_file 'energyuq.in'
            results_file 'energyuq.out'
            file_tag
            file_save
        work_directory named 'workdir'
        parameters_format
            aprepro

responses
    objective_functions = 1
    descriptors = 'energy_uj'
	numerical_gradients
	no_hessians


model
    id_model = 'TRUTH'
    single
      interface_pointer = 'TRUE_FN'