environment,
	method_pointer = 'BandB'
	tabular_data
		tabular_data_file = 'pce_samples.dat'
        custom_annotated header

variables,
    mixed
	active all
	discrete_design_range = 2
		initial_point        2           32
		lower_bounds         0            1
		upper_bounds         2           32
		descriptors      'CLK'  'N_THREADS'


method
	id_method 'comin'
	conmin_frcg

method
	id_method '1pac'
	nl2sol

method
	id_method 'tupac'
	mesh_adaptive_search

method
	id_method 'wets'
	coliny_solis_wets

method
	id_method 'dir'
	coliny_direct

method
	id_method 'nu'
	ncsu_direct

method
	id_method 'alladin'
	genie_direct

method
	id_method 'globo'
	efficient_global

method
	id_method 'stock'
	multifidelity_stoch_collocation
		sparse_grid_level_sequence 4 3 2


method
	id_method 'blu'
	multilevel_blue

method
	id_method 'gp'
	gpais

method
	id_method 'simp'
	sampling
		samples 20

method
	id_method 'bae'
	bayes_calibration
		queso
			chain_samples = 100
method
	id_method 'imp'
	importance_sampling
		adapt_import

method
  id_method = 'SubNLP'
  coliny_ea
    seed = 12345
    max_iterations = 100
    max_function_evaluations = 100

method
  id_method = 'BandB'
  branch_and_bound
    output verbose
    method_pointer = 'wets'

method
	id_method 'chaos'
	polynomial_chaos
		sparse_grid_level = 2
		variance_based_decomp

method,
	id_method = 'ada'
	adaptive_sampling
        seed = 42
		max_iterations = 20

interface
    analysis_driver = 'python3 dakota_wrapper.py'
        fork
            file_tag
            file_save
        parameters_format
            aprepro

responses
    response_functions = 1
    descriptors = 'energy_uj'
	numerical_gradients
	no_hessians